# Production environment template (main branch)
# Copy to .env.main locally if you want to run with production config.
# Never commit .env.main.

# Public client-side vars (safe for browser)
VITE_SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PROD_ANON_KEY
VITE_SITE_URL=https://YOUR_PROD_DOMAIN

# Server-side vars (secret on deploy platform)
SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_PROD_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_PROD_SERVICE_ROLE_KEY

RESEND_API_KEY=YOUR_RESEND_API_KEY
NOTIFY_EMAIL=contact@your-domain.com
