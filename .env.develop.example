# Development environment template (develop branch)
# Copy to .env.develop locally for development branch work.
# Never commit .env.develop.

# Public client-side vars (safe for browser)
VITE_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_DEV_ANON_KEY
VITE_SITE_URL=https://dev.YOUR_DOMAIN

# Server-side vars (secret on deploy platform)
SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_DEV_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_DEV_SERVICE_ROLE_KEY

RESEND_API_KEY=YOUR_RESEND_API_KEY
NOTIFY_EMAIL=contact@your-domain.com
