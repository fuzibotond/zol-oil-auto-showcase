# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC — safe to expose to the browser (prefix VITE_)
# ─────────────────────────────────────────────────────────────────────────────
# For branch-specific setups, use .env.main.example and .env.develop.example.

# Your Supabase project URL  (Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key  (Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Canonical origin for this environment — used in sitemap.xml and SEO tags
# No trailing slash!
VITE_SITE_URL=https://YOUR_DOMAIN


# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY SECRETS — never prefix with VITE_
# On Cloudflare Workers, set these in the Workers dashboard (Settings → Variables)
# or in .dev.vars for local Wrangler dev.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (server copy — same value as VITE_SUPABASE_URL, needed by auth middleware)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key — server copy needed by requireSupabaseAuth middleware
# Same value as VITE_SUPABASE_PUBLISHABLE_KEY above
SUPABASE_PUBLISHABLE_KEY=

# Supabase service-role key  (Settings → API → service_role secret)  ⚠️ NEVER expose
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key — used by the notify-lead Edge Function to send email alerts
# Create a free key at https://resend.com  (100 emails/day free tier)
RESEND_API_KEY=

# Email that receives new-lead notifications (the dealership's inbox)
NOTIFY_EMAIL=contact@your-domain.com
